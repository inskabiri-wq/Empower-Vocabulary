    {
      "name": "static-y",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5173", "--directory", "E:/vocab-trainer/y", "--bind", "127.0.0.1"],
      "port": 5173
    }
  ]
}
